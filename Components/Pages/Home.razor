@page "/"
@using JournalApp.Models
@inject JournalApp.Services.IJournalStorageService Storage
@inject NavigationManager Nav

<div class="dashboard-hero">
    <div class="welcome-section">
        <h1 class="welcome-title">Welcome back!</h1>
        <p class="welcome-subtitle">Your journey to mindfulness continues here. ✨</p>
    </div>

    <div class="quick-actions-grid row g-4 mb-5">
        <div class="col-md-4">
            <div class="action-card" @onclick='() => Nav.NavigateTo("/add-entry")'>
                <i class="bi bi-pencil-square" style="font-size: 2.5rem; color: var(--primary);"></i>
                <span>New Reflection</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="action-card" @onclick='() => Nav.NavigateTo("/view-entries")'>
                <i class="bi bi-book" style="font-size: 2.5rem; color: var(--accent-purple);"></i>
                <span>View Journal</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="action-card" @onclick='() => Nav.NavigateTo("/analytics")'>
                <i class="bi bi-graph-up-arrow" style="font-size: 2.5rem; color: #a855f7;"></i>
                <span>Mood Insights</span>
            </div>
        </div>
    </div>

    <!-- Getting Started Section -->
    <div class="promo-card card mb-5">
        <div class="card-body d-flex align-items-center gap-4 p-4">
            <div class="promo-icon" style="font-size: 3rem;">🚀</div>
            <div>
                <h4 class="card-title m-0 mb-1">Getting Started</h4>
                <p class="text-secondary m-0">Click "New Reflection" to capture your thoughts for today. Start building your habit!</p>
            </div>
            <button class="btn btn-primary ms-auto" @onclick='() => Nav.NavigateTo("/add-entry")'>
                Start Writing
            </button>
        </div>
    </div>

    <!-- Features Section -->
    <h3 class="section-header mb-4">Core Capabilities</h3>
    <div class="row g-4 mb-5">
        @foreach (var feature in Features)
        {
            <div class="col-md-6 col-lg-4">
                <div class="feature-card card h-100">
                    <div class="feature-icon mb-3">@feature.Icon</div>
                    <h5 class="feature-title">@feature.Title</h5>
                    <p class="feature-desc text-secondary small">@feature.Description</p>
                </div>
            </div>
        }
    </div>

    <!-- About Section -->
    <div class="about-card card mb-5">
        <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex align-items-center gap-2">
            <i class="bi bi-info-circle text-primary"></i>
            <h5 class="m-0">About MoodDiary</h5>
        </div>
        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-6">
                    <h6 class="text-uppercase small fw-bold text-secondary mb-2">The Mission</h6>
                    <p class="small text-secondary">MoodDiary is your personal companion for self-reflection. We use local SQLite storage to ensure your private thoughts stay on your device, providing a secure and offline-ready environment for your mental health journey.</p>
                </div>
                <div class="col-md-6">
                    <h6 class="text-uppercase small fw-bold text-secondary mb-2">App Specs</h6>
                    <div class="d-flex justify-content-between small text-secondary py-1 border-bottom border-opacity-10">
                        <span>Version</span>
                        <span class="fw-bold">9.0 Professional</span>
                    </div>
                    <div class="d-flex justify-content-between small text-secondary py-1 border-bottom border-opacity-10">
                        <span>Framework</span>
                        <span class="fw-bold">.NET 9 MAUI Blazor</span>
                    </div>
                    <div class="d-flex justify-content-between small text-secondary py-1">
                        <span>Storage</span>
                        <span class="fw-bold">Secure Local SQLite</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private record FeatureInfo(string Icon, string Title, string Description);

    private List<FeatureInfo> Features = new()
    {
        new FeatureInfo("📓", "Personal Reflections", "Write daily reflections in a distraction-free space."),
        new FeatureInfo("🎭", "Emotion Mapping", "Record how you feel to understand your mood shifts."),
        new FeatureInfo("🧩", "Custom Labels", "Add labels to entries to organize experiences."),
        new FeatureInfo("🗂️", "Smart Search", "Locate past entries using filters and keywords."),
        new FeatureInfo("📅", "Consistency Tracker", "Monitor how regularly you write and reflect."),
        new FeatureInfo("📈", "Insight Reports", "Visual trends reveal how your moods evolve.")
    };
}
