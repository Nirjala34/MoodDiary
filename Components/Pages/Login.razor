@page "/login"
@inject UserService UserService
@inject NavigationManager Nav

<div class="auth-page">
    <div class="auth-card">

        <h3 class="text-center">Welcome Back</h3>
        <p class="text-secondary mb-5">Please enter your details to sign in to your journal.</p>

        <div class="form-group mb-4">
            <label class="form-label fw-bold small text-secondary">EMAIL ADDRESS</label>
            <InputText type="email" @bind-Value="email" class="form-control" placeholder="example@email.com"/>
        </div>

        <div class="form-group mb-4">
            <label class="form-label fw-bold small text-secondary">PASSWORD</label>
            <InputText type="password" @bind-Value="password" class="form-control" placeholder="••••••••" />
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger py-2 small mb-4">@error</div>
        }

        <button class="btn btn-primary w-100 mb-4" @onclick="LoginUser">Sign In</button>

        <div class="text-center text-muted">
            New to MoodDiary? <a href="/register" class="text-primary fw-bold">Create an account</a>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string error = "";

    private async Task LoginUser()
    {
        var success = await UserService.LoginAsync(email, password);

        if (success)
            Nav.NavigateTo("/");
        else
            error = "Invalid email or password!";
    }
}
