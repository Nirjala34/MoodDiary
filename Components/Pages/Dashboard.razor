@page "/dashboard"
@using JournalApp.Models
@inject JournalApp.Services.IJournalStorageService Storage
@inject NavigationManager Nav

<div class="dashboard">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3 class="m-0">Your Mood Dashboard 🌿</h3>
            <div class="text-muted">Monitor your daily mood entries, reflections, and emotional trends.📖</div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/add-entry")'>+ New Entry</button>
            <button class="btn btn-outline-secondary" @onclick='() => Nav.NavigateTo("/view-entries")'>All Entries</button>
        </div>
    </div>

    <!-- TOP STATS -->
    <div class="dashboard-stats-row mb-3">
        <div class="dash-stat-card">
            <div class="dash-stat-label">Total Entries</div>
            <div class="dash-stat-value">@((entries?.Count ?? 0))</div>
            <div class="dash-stat-sub">entries</div>
        </div>

        <div class="dash-stat-card">
            <div class="dash-stat-label">Current Streak</div>
            <div class="dash-stat-value">@currentStreak</div>
            <div class="dash-stat-sub">days in a row</div>
        </div>

        <div class="dash-stat-card">
            <div class="dash-stat-label">Avg Words</div>
            <div class="dash-stat-value">@averageWordCount</div>
            <div class="dash-stat-sub">per entry</div>
        </div>

        <div class="dash-stat-card">
            <div class="dash-stat-label">Top Mood</div>
            <div class="dash-stat-value" style="font-size:2rem;">@mostFrequentMoodEmoji</div>
            <div class="dash-stat-sub">@mostFrequentMood</div>
        </div>

        <div class="dash-stat-card">
            <div class="dash-stat-label">Locked 🔒</div>
            <div class="dash-stat-value" style="color:#f59e0b;">@lockedEntriesCount</div>
            <div class="dash-stat-sub">protected</div>
        </div>
    </div>

    <!-- MOOD TREND -->
    <div class="card p-3 mb-3">
        <h6>Mood Trend (Last 7 Days)</h6>
        @if (!moodTrend.Any())
        {
            <div class="text-muted small">No recent entries.</div>
        }
        else
        {
            <ul class="list-unstyled d-flex gap-3 mb-0">
                @foreach (var mt in moodTrend)
                {
                    <li class="text-center">
                        <div>@mt.Date.ToString("MMM dd")</div>
                        <div class="mood-emoji display-6">@GetMoodEmoji(mt.Mood)</div>
                        <div class="small">@mt.Mood</div>
                    </li>
                }
            </ul>
        }
    </div>

    <!-- LAST ENTRY NOTES -->
    <div class="card p-3 mb-3">
        <h6>Last Entry Notes</h6>
        @if (lastEntry == null)
        {
            <div class="text-muted small">No entries yet.</div>
        }
        else
        {
            <div><strong>@lastEntry.Title</strong> - @lastEntry.CreatedAt.ToString("D")</div>
            @if(!string.IsNullOrWhiteSpace(lastEntry.OptionalNote))
            {
                <div class="text-muted small mt-1">📝 @lastEntry.OptionalNote</div>
            }
        }
    </div>

    <!-- RECENT TAGS -->
    <div class="card p-3 mb-3">
        <h6>Recent Tags</h6>
        @if (entries == null || !entries.SelectMany(e => e.Tags ?? new List<string>()).Any())
        {
            <div class="text-muted small">No tags yet.</div>
        }
        else
        {
            var tags = entries
                .SelectMany(e => e.Tags ?? new List<string>())
                .GroupBy(t => t)
                .OrderByDescending(g => g.Count())
                .Take(10);

            <div>
                @foreach (var t in tags)
                {
                    <span class="badge me-1 mb-1" style="background-color: var(--tag-bg); color:white;">
                        #@t.Key
                    </span>
                }
            </div>
        }
    </div>

    <!-- RECENT ENTRIES -->
    <div class="card p-4 mt-3">
        <h5>Recent Entries</h5>
        @if (entries == null || !entries.Any())
        {
            <div class="text-center py-5 text-muted">No entries yet.</div>
        }
        else
        {
            <ul class="list-unstyled">
                @foreach (var e in entries.OrderByDescending(e => e.CreatedAt).Take(5))
                {
                    <li class="mb-3">
                        <div class="fw-bold">@e.Title</div>
                        <div class="text-muted small">@e.CreatedAt.ToString("D")</div>
                    </li>
                }
            </ul>
        }
    </div>
</div>


@code {
    private List<JournalEntry> entries = new();
    private int currentStreak = 0;
    private double averageWordCount = 0;
    private string mostFrequentMood = "";
    private string mostFrequentMoodEmoji = "";
    private JournalEntry? lastEntry;
    private List<(DateTime Date, string Mood)> moodTrend = new();

    //  NEW
    private int lockedEntriesCount = 0;

    protected override async Task OnInitializedAsync()
    {
        entries = await Storage.GetEntriesAsync() ?? new List<JournalEntry>();
        entries = entries.OrderByDescending(e => e.CreatedAt).ToList();

        lastEntry = entries.FirstOrDefault();
        currentStreak = CalculateCurrentStreak(entries);
        averageWordCount = CalculateAverageWords(entries);
        mostFrequentMood = GetMostFrequentMood(entries);
        mostFrequentMoodEmoji = GetMoodEmoji(mostFrequentMood);
        moodTrend = GetMoodTrend(entries, 7);

        // LOCKED ENTRIES COUNT
        lockedEntriesCount = entries.Count(e => e.IsLocked);
    }
    private readonly Dictionary<string, string> MoodEmojiMap = new()
{
    // 😊 POSITIVE
    { "Happy", "😊" },
    { "Excited", "🤩" },
    { "Relaxed", "😌" },
    { "Grateful", "🙏" },
    { "Confident", "💪" },

    // 😐 NEUTRAL
    { "Calm", "😌" },
    { "Thoughtful", "🤔" },
    { "Curious", "🧐" },
    { "Nostalgic", "🕰️" },
    { "Bored", "😴" },

    // 😔 NEGATIVE
    { "Sad", "😢" },
    { "Angry", "😠" },
    { "Stressed", "😰" },
    { "Lonely", "🥺" },
    { "Anxious", "😟" }
};


    private string GetMoodEmoji(string mood)
{
    if (string.IsNullOrWhiteSpace(mood))
        return "🙂";

    return MoodEmojiMap.TryGetValue(mood, out var emoji)
        ? emoji
        : "🙂";
}


    private int CalculateCurrentStreak(List<JournalEntry> entries)
    {
        if (!entries.Any()) return 0;
        var dates = entries.Select(e => e.CreatedAt.Date).Distinct().OrderByDescending(d => d).ToList();
        int streak = 1;
        DateTime previousDate = dates[0];
        for (int i = 1; i < dates.Count; i++)
        {
            if ((previousDate - dates[i]).Days == 1)
            {
                streak++;
                previousDate = dates[i];
            }
            else break;
        }
        return streak;
    }

    private double CalculateAverageWords(List<JournalEntry> entries)
    {
        if (!entries.Any()) return 0;
        return Math.Round(entries.Average(e => e.Content.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length), 1);
    }

    private string GetMostFrequentMood(List<JournalEntry> entries)
    {
        if (!entries.Any()) return "";
        return entries.Where(e => !string.IsNullOrEmpty(e.PrimaryMood))
                      .GroupBy(e => e.PrimaryMood)
                      .OrderByDescending(g => g.Count())
                      .FirstOrDefault()?.Key ?? "";
    }

    private List<(DateTime Date, string Mood)> GetMoodTrend(List<JournalEntry> entries, int days)
    {
        var lastDays = DateTime.Today.AddDays(-days + 1);
        return entries
            .Where(e => e.CreatedAt.Date >= lastDays)
            .OrderBy(e => e.CreatedAt.Date)
            .Select(e => (e.CreatedAt.Date, e.PrimaryMood))
            .ToList();
 
    }
}