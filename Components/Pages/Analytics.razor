@page "/analytics"
@using JournalApp.Models
@inject JournalApp.Services.IJournalStorageService Storage

<h1 class="page-title">📊 Analytics & Insights</h1>

<!-- 🔍 FILTER SECTION -->
<div class="filter-card">
    <div class="filter-grid">
        <div class="filter-group">
            <label>Start Date</label>
            <input type="date" class="form-control" @bind="startDate" />
        </div>
        <div class="filter-group">
            <label>End Date</label>
            <input type="date" class="form-control" @bind="endDate" />
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-primary" @onclick="ApplyFilter">Apply Analytics</button>
        <button class="btn btn-secondary" @onclick="ResetFilter">Reset</button>
    </div>
</div>


<!-- STATS HEADER ROW -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="small text-secondary mb-1">🔥 Current Streak</div>
            <div class="stat-value">@currentStreak</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="small text-secondary mb-1">🏆 Longest Streak</div>
            <div class="stat-value">@longestStreak</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card text-center">
            <div class="small text-secondary mb-1">📄 Total Entries</div>
            <div class="stat-value">@totalEntries</div>
        </div>
    </div>
</div>

<!-- MISSED DAYS SECTION (SEPARATE) -->
<div class="card p-3 mb-4">
    <div class="d-flex align-items-center gap-2 mb-3">
        <span style="font-size: 1.25rem;">⚠️</span>
        <h6 class="m-0 fw-bold">Missed Days</h6>
    </div>

    <div class="d-flex flex-wrap gap-2 align-items-center">
        @if (missedDays.Any())
        {
            var displayList = showAllMissedDays ? missedDays : missedDays.Take(12).ToList();
            
            @foreach (var d in displayList)
            {
                <span class="badge bg-danger rounded-pill" style="font-size: 0.8rem; padding: 0.5rem 0.8rem; opacity: 0.9;">
                    @d.ToString("MMM dd")
                </span>
            }

            @if (missedDays.Count > 12)
            {
                <button class="btn btn-link btn-sm p-0 ms-2 text-decoration-none fw-bold" 
                        @onclick="() => showAllMissedDays = !showAllMissedDays"
                        style="color: var(--primary);">
                    @(showAllMissedDays ? "Show Less" : $"+{missedDays.Count - 12} more")
                </button>
            }
        }
        else
        {
            <div class="text-success small fw-bold">Perfect! No days missed in this period. 🎉</div>
        }
    </div>
</div>

<!-- ANALYTICS -->
<div class="analytics-grid">

    <div class="analytics-card">
        <h5 class="mb-4">😊 Mood Distribution</h5>
        @if (!filteredEntries.Any())
        {
            <div class="text-muted">No data available for this range</div>
        }
        else
        {
            <div class="mood-dist">
                @foreach (var c in new[] { "Positive", "Neutral", "Negative" })
                {
                    var count = GetCategoryCount(c);
                    var percent = GetCategoryPercentage(c);

                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-1">
                            <span>@GetCategoryEmoji(c) <strong>@c</strong></span>
                            <span class="text-secondary small">@count (@percent%)</span>
                        </div>
                        <div class="mood-bar">
                            <div class="mood-fill @c.ToLower()" style="width:@percent%"></div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="analytics-card d-flex flex-column align-items-center justify-content-center text-center">
        <h5 class="mb-3">⭐ Most Frequent Mood</h5>
        @if (mostFrequentMood != null)
        {
            <div style="font-size: 4rem;">@GetMoodEmoji(mostFrequentMood)</div>
            <h4 class="mt-2 fw-bold text-primary">@mostFrequentMood</h4>
        }
        else
        {
            <div class="text-muted">No entries yet</div>
        }
    </div>

    <div class="analytics-card">
        <h5 class="mb-4">🏷 Most Used Tags</h5>
        @if (mostUsedTags.Any())
        {
            <div class="d-flex flex-wrap gap-2">
                @foreach (var tag in mostUsedTags)
                {
                    <span class="tag">#@tag</span>
                }
            </div>
        }
        else
        {
            <div class="text-muted">No tags recorded</div>
        }
    </div>

    <div class="analytics-card d-flex flex-column align-items-center justify-content-center text-center">
        <h5 class="mb-3">✍ Writing Velocity</h5>
        <div class="stat-value">@averageWords</div>
        <div class="text-secondary small">Avg words per entry</div>
    </div>

    <div class="analytics-card" style="grid-column: 1 / -1;">
        <h5 class="mb-4">📂 Category Breakdown</h5>
        @if (categoryBreakdown.Any())
        {
            <div class="d-flex flex-wrap gap-2">
                @foreach (var c in categoryBreakdown)
                {
                    <span class="chip">@GetMoodEmoji(c.Key) @c.Key <span class="badge bg-white text-primary ms-2">@c.Value</span></span>
                }
            </div>
        }
        else
        {
            <div class="text-muted">No detailed breakdown available</div>
        }
    </div>

</div>

@code {
    private List<JournalEntry> entries = new();
    private List<JournalEntry> filteredEntries = new();
    private List<string> AllTags = new();

    private DateTime? startDate;
    private DateTime? endDate;
    private string? searchText;
    private string? selectedMood;
    private string? selectedTag;

    private int currentStreak;
    private int longestStreak;
    private int totalEntries;
    private int averageWords;
    private string? mostFrequentMood;

    private List<string> mostUsedTags = new();
    private Dictionary<string, int> categoryBreakdown = new();
    private List<DateTime> missedDays = new();
    private bool showAllMissedDays = false;

    protected override async Task OnInitializedAsync()
    {
        entries = await Storage.GetEntriesAsync() ?? new();
        UpdateAllTags();
        ApplyFilter();
    }

    private void UpdateAllTags()
    {
        AllTags = entries
            .SelectMany(e => e.Tags ?? new List<string>())
            .Distinct()
            .OrderBy(t => t)
            .ToList();
    }

    private void ApplyFilter()
    {
        var query = entries.AsEnumerable();

        if (startDate.HasValue)
            query = query.Where(e => e.CreatedAt.Date >= startDate.Value.Date);

        if (endDate.HasValue)
            query = query.Where(e => e.CreatedAt.Date <= endDate.Value.Date);

        if (!string.IsNullOrWhiteSpace(searchText))
            query = query.Where(e =>
                (!string.IsNullOrEmpty(e.Title) &&
                 e.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                ||
                (!string.IsNullOrEmpty(e.Content) &&
                 e.Content.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            );

        if (!string.IsNullOrWhiteSpace(selectedMood))
            query = query.Where(e => e.PrimaryMood == selectedMood);

        if (!string.IsNullOrWhiteSpace(selectedTag))
            query = query.Where(e =>
                e.Tags != null &&
                e.Tags.Any(t => t.Contains(selectedTag, StringComparison.OrdinalIgnoreCase)));

        filteredEntries = query.ToList();

        ComputeMissedDays();
        ComputeStats(filteredEntries);
    }

    private void ResetFilter()
    {
        startDate = null;
        endDate = null;
        searchText = null;
        selectedMood = null;
        selectedTag = null;
        ApplyFilter();
    }

    private void ComputeMissedDays()
    {
        missedDays.Clear();

        DateTime firstDay = startDate?.Date ?? (entries.Any() ? entries.Min(e => e.CreatedAt.Date) : DateTime.Today);
        DateTime lastDay = endDate?.Date ?? DateTime.Today;

        var existingDates = entries
            .Where(e => e.CreatedAt.Date >= firstDay && e.CreatedAt.Date <= lastDay)
            .Select(e => e.CreatedAt.Date)
            .ToHashSet();

        for (DateTime day = firstDay; day <= lastDay; day = day.AddDays(1))
        {
            if (!existingDates.Contains(day))
                missedDays.Add(day);
        }
    }
    private int GetCategoryCount(string category)
    {
        return filteredEntries.Count(e => GetMoodCategory(e.PrimaryMood) == category);
    }

    private int GetCategoryPercentage(string category)
    {
        if (!filteredEntries.Any()) return 0;

        var count = GetCategoryCount(category);
        return (int)Math.Round(count * 100.0 / filteredEntries.Count);
    }

    private string? GetMoodCategory(string? mood)
    {
        if (mood == null) return null;

        return mood switch
        {
            "Happy" or "Excited" or "Relaxed" or "Grateful" or "Confident" => "Positive",
            "Calm" or "Thoughtful" or "Curious" or "Nostalgic" or "Bored" => "Neutral",
            "Sad" or "Angry" or "Stressed" or "Lonely" or "Anxious" => "Negative",
            _ => null
        };
    }

    private string GetCategoryEmoji(string c) => c switch
    {
        "Positive" => "😊",
        "Neutral" => "😐",
        "Negative" => "😔",
        _ => "🙂"
    };

    private void ComputeStats(List<JournalEntry> data)
    {
        if (!data.Any())
        {
            mostFrequentMood = null;
            mostUsedTags.Clear();
            categoryBreakdown.Clear();
            averageWords = 0;
            currentStreak = longestStreak = totalEntries = 0;
            return;
        }

        mostFrequentMood = data
            .Where(e => !string.IsNullOrEmpty(e.PrimaryMood))
            .GroupBy(e => e.PrimaryMood)
            .OrderByDescending(g => g.Count())
            .Select(g => g.Key)
            .FirstOrDefault();

        mostUsedTags = data
            .SelectMany(e => e.Tags ?? new())
            .GroupBy(t => t)
            .OrderByDescending(g => g.Count())
            .Take(6)
            .Select(g => g.Key)
            .ToList();

        var words = data
            .Where(e => !string.IsNullOrWhiteSpace(e.Content))
            .Select(e => e.Content.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length);

        averageWords = words.Any() ? (int)Math.Round(words.Average()) : 0;

        categoryBreakdown = data
            .Where(e => !string.IsNullOrEmpty(e.PrimaryMood))
            .GroupBy(e => e.PrimaryMood)
            .ToDictionary(g => g.Key, g => g.Count());

        ComputeStreaks(filteredEntries);
    }

    private void ComputeStreaks(List<JournalEntry> data)
    {
        if (!data.Any())
        {
            currentStreak = longestStreak = totalEntries = 0;
            return;
        }

        var allDates = data
            .Select(e => e.CreatedAt.Date)
            .Distinct()
            .OrderBy(d => d)
            .ToList();

        totalEntries = allDates.Count;

        int temp = 1;
        longestStreak = 1;
        for (int i = 1; i < allDates.Count; i++)
        {
            temp = (allDates[i] - allDates[i - 1]).Days == 1 ? temp + 1 : 1;
            longestStreak = Math.Max(longestStreak, temp);
        }

        currentStreak = 1;
        for (int i = allDates.Count - 1; i > 0; i--)
        {
            if ((allDates[i] - allDates[i - 1]).Days == 1)
                currentStreak++;
            else
                break;
        }
    }

    private readonly Dictionary<string, string> MoodEmojis = new()
    {
        { "Happy", "😊" }, { "Excited", "🤩" }, { "Relaxed", "😌" },
        { "Grateful", "🙏" }, { "Confident", "💪" },
        { "Calm", "😌" }, { "Thoughtful", "🤔" }, { "Curious", "🧐" },
        { "Nostalgic", "🕰️" }, { "Bored", "😴" },
        { "Sad", "😢" }, { "Angry", "😠" }, { "Stressed", "😰" },
        { "Lonely", "🥺" }, { "Anxious", "😟" }
    };

    private string GetMoodEmoji(string? mood)
        => mood != null && MoodEmojis.TryGetValue(mood, out var e) ? e : "🙂";
}
