@page "/calendar"
@using JournalApp.Models
@inject JournalApp.Services.IJournalStorageService Storage
@inject NavigationManager Nav

<h3 style="margin-top:30px;margin-bottom:20px;font-size:2rem;font-weight:900;letter-spacing:0.8px;">
    Calendar
</h3>

@if (entries == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card p-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <button class="btn btn-sm btn-outline-secondary" @onclick="PrevMonth">← Prev</button>
            <h5 class="m-0">@currentMonth.ToString("MMMM yyyy")</h5>
            <button class="btn btn-sm btn-outline-secondary" @onclick="NextMonth">Next →</button>
        </div>

        <div class="calendar-grid">
            @foreach (var day in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
            {
                <div class="calendar-header">@day</div>
            }

            @foreach (var date in datesInMonth)
            {
                var has = entriesByDate.ContainsKey(date.Date);
                var entryCount = has ? entriesByDate[date.Date].Count : 0;
                var isCurrentMonth = date.Month == currentMonth.Month;

                <div class="calendar-day @(has ? "has-entry" : "") @(!isCurrentMonth ? "other-month" : "") @(date.Date == DateTime.Today ? "today" : "")"
                     @onclick="() => OnDateClick(date)">
                    <div class="day-number">@date.Day</div>

                    @if (has)
                    {
                        var dayEntries = entriesByDate[date.Date];
                        var mood = dayEntries
                            .OrderByDescending(e => e.CreatedAt)
                            .First()
                            .PrimaryMood;

                        <div class="entry-emoji">@GetMoodEmoji(mood)</div>
                        <div class="entry-count">@entryCount</div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
.calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
    margin-top: 1rem;
}

.calendar-header {
    font-weight: 700;
    text-align: center;
    padding: 8px 0;
    color: #9ca3af;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.calendar-day {
    aspect-ratio: 1;
    border: 1.5px solid #ede9f6;
    border-radius: 12px;
    padding: 6px;
    background: #faf9ff;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.18s ease;
    min-height: 72px;
}

.calendar-day:hover {
    background: #f3eeff;
    border-color: #a78bfa;
    transform: translateY(-2px);
    box-shadow: 0 4px 14px rgba(139, 92, 246, 0.12);
}

.calendar-day.has-entry {
    background: linear-gradient(135deg, #f5f0ff 0%, #ede9f6 100%);
    border-color: #8b5cf6;
    box-shadow: 0 2px 10px rgba(139, 92, 246, 0.15);
}

.calendar-day.has-entry:hover {
    background: linear-gradient(135deg, #ede9f6 0%, #ddd6fe 100%);
    box-shadow: 0 6px 18px rgba(139, 92, 246, 0.22);
}

.calendar-day.other-month {
    opacity: 0.35;
    background: #f9f9f9;
    border-color: #f0f0f0;
}

.calendar-day.today {
    border-color: #7c3aed;
    ring: 2px solid #7c3aed;
    box-shadow: 0 0 0 2px #7c3aed22;
}

.day-number {
    font-weight: 700;
    color: #1e1b4b;
    font-size: 1rem;
    line-height: 1;
}

.calendar-day.has-entry .day-number {
    color: #6d28d9;
}

.calendar-day.other-month .day-number {
    color: #c4b5fd;
}

.entry-emoji {
    font-size: 1.3rem;
    margin-top: 4px;
    font-family: 'Segoe UI Emoji', 'Apple Color Emoji', 'Noto Color Emoji', sans-serif;
    line-height: 1;
}

.entry-count {
    font-size: 0.62rem;
    color: #7c3aed;
    margin-top: 2px;
    font-weight: 700;
    background: #ede9f6;
    border-radius: 999px;
    padding: 1px 6px;
}
</style>

@code {
    private List<JournalEntry> entries = new();
    private DateTime currentMonth = DateTime.Now;
    private List<DateTime> datesInMonth = new();
    private Dictionary<DateTime, List<JournalEntry>> entriesByDate = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadMonth();
    }

    private async Task LoadMonth()
    {
        entries = (await Storage.GetEntriesAsync()) ?? new List<JournalEntry>();

        var firstDay = new DateTime(currentMonth.Year, currentMonth.Month, 1);
        var daysInMonth = DateTime.DaysInMonth(currentMonth.Year, currentMonth.Month);
        var startDayOfWeek = (int)firstDay.DayOfWeek;

        datesInMonth = new List<DateTime>();

        for (int i = startDayOfWeek; i > 0; i--)
            datesInMonth.Add(firstDay.AddDays(-i));

        for (int d = 1; d <= daysInMonth; d++)
            datesInMonth.Add(new DateTime(currentMonth.Year, currentMonth.Month, d));

        while (datesInMonth.Count % 7 != 0)
            datesInMonth.Add(datesInMonth.Last().AddDays(1));

        entriesByDate = entries
            .GroupBy(e => e.CreatedAt.Date)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    private async Task PrevMonth()
    {
        currentMonth = currentMonth.AddMonths(-1);
        await LoadMonth();
    }

    private async Task NextMonth()
    {
        currentMonth = currentMonth.AddMonths(1);
        await LoadMonth();
    }

    private void OnDateClick(DateTime date)
    {
        if (entriesByDate.ContainsKey(date.Date))
        {
            var entryId = entriesByDate[date.Date]
                .OrderByDescending(e => e.CreatedAt)
                .First()
                .Id;

            Nav.NavigateTo($"/entry/{entryId}");
        }
    }

    //  ALL MOOD EMOJIS (FINAL)
    private string GetMoodEmoji(string mood) => mood switch
    {
        "Happy" => "😊",
        "Excited" => "🤩",
        "Relaxed" => "😌",
        "Grateful" => "🙏",
        "Confident" => "💪",
        "Calm" => "😐",
        "Thoughtful" => "🤔",
        "Curious" => "🧐",
        "Nostalgic" => "🕰️",
        "Bored" => "😴",
        "Sad" => "😢",
        "Angry" => "😠",
        "Stressed" => "😰",
        "Lonely" => "🥺",
        "Anxious" => "😟",
        _ => ""
    };
}
