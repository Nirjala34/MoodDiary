@page "/register"
@inject UserService UserService
@inject NavigationManager Nav

<div class="auth-page">
    <div class="auth-card">

        <h4 class="text-center mb-4">Register</h4>

        <div class="mb-3">
            <label class="form-label">Name</label>
            <InputText @bind-Value="name" class="form-control" placeholder="Enter your name" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <InputText type="email" @bind-Value="email" class="form-control" placeholder="Enter your email" />
        </div>

        <div class="mb-3">
            <label class="form-label">Password</label>
            <InputText type="password" @bind-Value="password" class="form-control" placeholder="Enter password" />
        </div>

        <div class="mb-3">
            <label class="form-label">Confirm Password</label>
            <InputText type="password" @bind-Value="confirmPassword" class="form-control" placeholder="Confirm password" />
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="text-danger mb-3">@error</div>
        }

        <button class="btn btn-primary w-100 mb-3" @onclick="RegisterUser">Register</button>

        <div class="text-center text-muted">
            Already have an account? <a href="/login">Login</a>
        </div>
    </div>
</div>

@code {
    private string name = "";
    private string email = "";
    private string password = "";
    private string confirmPassword = "";
    private string error = "";

    private async Task RegisterUser()
    {
        error = "";

        if (string.IsNullOrWhiteSpace(name) ||
            string.IsNullOrWhiteSpace(email) ||
            string.IsNullOrWhiteSpace(password))
        {
            error = "Please fill in all fields!";
            return;
        }

        if (password != confirmPassword)
        {
            error = "Passwords do not match!";
            return;
        }

        var success = await UserService.RegisterAsync(name, email, password);

        if (success)
            Nav.NavigateTo("/login");
        else
            error = "Registration failed! Email might already be in use.";
    }
}


<style>
.auth-page {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 90vh;
    background: linear-gradient(135deg, #0f1820, #1b2430);
}

.auth-card {
    background-color: #1b2430;
    padding: 2.5rem;
    border-radius: 12px;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 8px 25px rgba(0,0,0,0.4);
    color: #fff;
}

.auth-card h2 {
    font-weight: 700;
    color: #2b6be6;
}
.auth-card h4 {
    color: #fff;
    font-weight: 500;
}

.auth-card .form-control {
    background-color:#ededed;
    color: #000000;
    border: 1px solid #333;
    border-radius: 8px;
    padding: 10px;
    transition: all 0.2s;
}
.auth-card .form-control:focus {
    border-color: #2b6be6;
    box-shadow: 0 0 5px rgba(43,107,230,0.5);
    outline: none;
}

.auth-card .btn-primary {
    background-color: #2b6be6;
    border-color: #2b6be6;
    font-weight: 600;
    border-radius: 8px;
    padding: 0.6rem;
    transition: all 0.2s;
}
.auth-card .btn-primary:hover {
    background-color: #1d54c4;
    border-color: #1d54c4;
}
.user-greeting {
    color: #ffffff;
    font-weight: 500;
    margin-top: 1rem;
}
.auth-card a {
    color: #2b6be6;
    font-weight: 500;
}
.auth-card a:hover {
    text-decoration: underline;
}
</style>


