@page "/register"
@inject UserService UserService
@inject NavigationManager Nav

<div class="auth-page">
    <div class="auth-card">

        <h3 class="text-center">Create Account</h3>
        <p class="text-secondary mb-5">Join our community and start your mindfulness journey today.</p>

        <div class="form-group mb-4">
            <label class="form-label fw-bold small text-secondary">FULL NAME</label>
            <InputText @bind-Value="name" class="form-control" placeholder="John Doe" />
        </div>

        <div class="form-group mb-4">
            <label class="form-label fw-bold small text-secondary">EMAIL ADDRESS</label>
            <InputText type="email" @bind-Value="email" class="form-control" placeholder="example@email.com" />
        </div>

        <div class="form-group mb-4">
            <label class="form-label fw-bold small text-secondary">PASSWORD</label>
            <InputText type="password" @bind-Value="password" class="form-control" placeholder="••••••••" />
        </div>

        <div class="form-group mb-4">
            <label class="form-label fw-bold small text-secondary">CONFIRM PASSWORD</label>
            <InputText type="password" @bind-Value="confirmPassword" class="form-control" placeholder="••••••••" />
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger py-2 small mb-4">@error</div>
        }

        <button class="btn btn-primary w-100 mb-4" @onclick="RegisterUser">Create Account</button>

        <div class="text-center text-muted">
            Already have an account? <a href="/login" class="text-primary fw-bold">Sign In</a>
        </div>
    </div>
</div>

@code {
    private string name = "";
    private string email = "";
    private string password = "";
    private string confirmPassword = "";
    private string error = "";

    private async Task RegisterUser()
    {
        error = "";

        if (string.IsNullOrWhiteSpace(name) ||
            string.IsNullOrWhiteSpace(email) ||
            string.IsNullOrWhiteSpace(password))
        {
            error = "Please fill in all fields!";
            return;
        }

        if (password != confirmPassword)
        {
            error = "Passwords do not match!";
            return;
        }

        var success = await UserService.RegisterAsync(name, email, password);

        if (success)
            Nav.NavigateTo("/login");
        else
            error = "Registration failed! Email might already be in use.";
    }
}
