@page "/view-entries"
@using JournalApp.Models
@inject JournalApp.Services.IJournalStorageService Storage
@inject JournalApp.Services.PdfExportService PdfService
@inject PinService PinService
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3 class="page-title">📔 Journal Entries</h3>

<!-- 🔍 FILTER SECTION -->
<div class="filter-card mb-3">
    <div class="filter-grid">
        <div class="filter-group">
            <label>Start Date</label>
            <input type="date" class="form-control" @bind="startDate" />
        </div>
        <div class="filter-group">
            <label>End Date</label>
            <input type="date" class="form-control" @bind="endDate" />
        </div>
        <div class="filter-group">
            <label>Search</label>
            <input type="text" class="form-control" placeholder="Search title or content" @bind="searchText" />
        </div>
        <div class="filter-group">
            <label>Mood</label>
            <select class="form-select" @bind="selectedMood">
                <option value="">All Moods</option>
                <optgroup label="😊 Positive">
                    @foreach (var mood in MoodCategories["Positive"]) { <option value="@mood">@mood</option> }
                </optgroup>
                <optgroup label="😐 Neutral">
                    @foreach (var mood in MoodCategories["Neutral"]) { <option value="@mood">@mood</option> }
                </optgroup>
                <optgroup label="😔 Negative">
                    @foreach (var mood in MoodCategories["Negative"]) { <option value="@mood">@mood</option> }
                </optgroup>
            </select>
        </div>
        <div class="filter-group">
            <label>Tag</label>
            <select class="form-select" @bind="selectedTag">
                <option value="">All Tags</option>
                @foreach (var tag in AllTags) { <option value="@tag">@tag</option> }
            </select>
        </div>
    </div>

    <div class="d-flex gap-2 mt-3 flex-wrap">
        <button class="btn btn-primary" @onclick="ApplyFilter">Apply</button>
        <button class="btn btn-secondary" @onclick="ResetFilter">Reset</button>
        <button class="btn btn-success" disabled="@(!FilteredEntries.Any())" @onclick="ExportFiltered">
            📄 Export Multiple Journal
        </button>
    </div>

    @if (!string.IsNullOrEmpty(selectedMood))
    {
        <div class="mt-2 fw-bold">
            Selected Mood: @GetMoodEmoji(selectedMood) @selectedMood
        </div>
    }
</div>


@if (!FilteredEntries.Any())
{
    <p class="text-muted">No entries found.</p>
}
else
{
    @foreach (var entry in PagedEntries)
    {
        <div class="card p-3 mb-3">

            <div class="d-flex justify-content-between align-items-center">
                <h5>
                    @if (entry.IsLocked)
                    {
                        <span>🔒 Locked Entry</span>
                    }
                    else
                    {
                        @entry.Title
                    }
                </h5>
                <small class="text-muted">
                    @entry.CreatedAt.ToString("dd MMM yyyy")
                </small>
            </div>

            @if (!entry.IsLocked || unlockedEntries.Contains(entry.Id))
            {
                <p class="mt-2 fw-bold">
                    @GetMoodEmoji(entry.PrimaryMood) @entry.PrimaryMood
                </p>

                <div style="white-space:pre-wrap">
                    @((MarkupString)entry.Content.Replace("\n", "<br/>"))
                </div>

                @if (!string.IsNullOrWhiteSpace(entry.OptionalNote))
                {
                    <hr />
                    <strong>Optional Note</strong>
                    <p>@entry.OptionalNote</p>
                }
            }
            else
            {
                <p class="text-muted fst-italic mt-2">
                    This journal entry is locked.
                </p>
            }

            <!-- 🔘 ACTION BUTTONS -->
            <div class="d-flex gap-2 mt-3 flex-wrap">

                @if (entry.IsLocked)
                {
                    <button class="btn btn-sm btn-outline-primary"
                            @onclick="() => RequestUnlock(entry)">
                        🔓 Unlock
                    </button>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-warning"
                            @onclick="() => LockEntry(entry)">
                        🔒 Lock
                    </button>
                }

                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="() => Edit(entry)">
                    Edit
                </button>

                <button class="btn btn-sm btn-outline-danger"
                        @onclick="() => Delete(entry.Id)">
                    Delete
                </button>

                <button class="btn btn-sm btn-outline-success"
                        @onclick="() => ExportSingleEntry(entry)">
                    Export PDF
                </button>
            </div>
        </div>
    }

    <!-- PAGINATION -->
    <div class="pagination-ui d-flex justify-content-between align-items-center mt-4 p-3 card flex-row">
        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-secondary btn-sm" disabled="@(_page == 1)" @onclick="Prev">‹</button>
            <span class="small mx-2">Page @_page of @TotalPages</span>
            <button class="btn btn-secondary btn-sm" disabled="@(_page == TotalPages)" @onclick="Next">›</button>
        </div>

        <div class="d-flex align-items-center gap-3 small text-secondary">
            @if (FilteredEntries.Any())
            {
                <span>Showing @(((_page - 1) * PageSize) + 1)-@(Math.Min(_page * PageSize, FilteredEntries.Count)) of @FilteredEntries.Count</span>
            }
            else
            {
                <span>No items to show</span>
            }
            <select class="form-select form-select-sm w-auto" value="@PageSize" @onchange="OnPageSizeChanged">
                @foreach (var size in PageSizeOptions)
                {
                    <option value="@size">@size per page</option>
                }
            </select>
        </div>
    </div>

}

<!-- 🔐 PIN MODAL -->
@if (showPinPrompt)
{
    <div class="pin-overlay">
        <div class="pin-box">
            <h5>🔐 Enter PIN</h5>

            <input type="password"
                   class="form-control mb-2"
                   @bind="enteredPin"
                   placeholder="Enter PIN" />

            @if (!string.IsNullOrEmpty(pinError))
            {
                <div class="text-danger mb-2">@pinError</div>
            }

            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="UnlockAndProceed">Unlock</button>
                <button class="btn btn-secondary" @onclick="CancelUnlock">Cancel</button>
            </div>
        </div>
    </div>
}

@code {

    private List<JournalEntry> allEntries = new();
    private List<JournalEntry> FilteredEntries = new();
    private HashSet<Guid> unlockedEntries = new();

    private List<string> AllTags = new();

    private DateTime? startDate;
    private DateTime? endDate;
    private string? searchText;
    private string? selectedMood;
    private string? selectedTag;

    private JournalEntry? pendingEntry;
    private bool navigateAfterUnlock;

    private bool showPinPrompt;
    private bool isExporting = false;
    private string enteredPin = "";
    private string pinError = "";
    private List<JournalEntry> lockedEntriesToUnlock = new();
private bool exportAfterUnlock = false;

    private int _page = 1;
    private int PageSize = 5;

private readonly int[] PageSizeOptions = { 5, 10, 25, 50 };


    protected override async Task OnInitializedAsync()
    {
        allEntries = await Storage.GetEntriesAsync() ?? new();
        UpdateAllTags();
        ApplyFilter();
    }

    private void UpdateAllTags()
    {
        AllTags = allEntries
            .SelectMany(e => e.Tags ?? new())
            .Distinct()
            .OrderBy(t => t)
            .ToList();
    }

    private void ApplyFilter()
    {
        var query = allEntries.AsEnumerable();

        if (startDate.HasValue)
            query = query.Where(e => e.CreatedAt.Date >= startDate.Value.Date);

        if (endDate.HasValue)
            query = query.Where(e => e.CreatedAt.Date <= endDate.Value.Date);

        if (!string.IsNullOrWhiteSpace(searchText))
            query = query.Where(e =>
                (!string.IsNullOrEmpty(e.Title) &&
                 e.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                ||
                (!string.IsNullOrEmpty(e.Content) &&
                 e.Content.Contains(searchText, StringComparison.OrdinalIgnoreCase)));

        if (!string.IsNullOrWhiteSpace(selectedMood))
            query = query.Where(e => e.PrimaryMood == selectedMood);

        if (!string.IsNullOrWhiteSpace(selectedTag))
            query = query.Where(e =>
                e.Tags != null &&
                e.Tags.Any(t => t.Contains(selectedTag, StringComparison.OrdinalIgnoreCase)));

        FilteredEntries = query
            .OrderByDescending(e => e.CreatedAt)
            .ToList();

        _page = 1;
    }
    private List<PageItem> GetPageItems()
{
    var items = new List<PageItem>();

    if (TotalPages <= 6)
    {
        for (int i = 1; i <= TotalPages; i++)
            items.Add(new PageItem(i, false));

        return items;
    }

    items.Add(new PageItem(1, false));

    if (_page > 3)
        items.Add(new PageItem(null, true)); // dots

    for (int i = Math.Max(2, _page - 1); i <= Math.Min(TotalPages - 1, _page + 1); i++)
        items.Add(new PageItem(i, false));

    if (_page < TotalPages - 2)
        items.Add(new PageItem(null, true)); // dots

    items.Add(new PageItem(TotalPages, false));

    return items;
}
private class PageItem
{
    public int? Page { get; set; }
    public bool IsDots { get; set; }

    public PageItem(int? page, bool isDots)
    {
        Page = page;
        IsDots = isDots;
    }
}
private void OnPageSizeChanged(ChangeEventArgs e)
{
    PageSize = int.Parse(e.Value!.ToString()!);
    _page = 1; // go back to first page
}

    private void ResetFilter()
    {
        startDate = endDate = null;
        searchText = selectedMood = selectedTag = null;
        ApplyFilter();
    }

    private int TotalPages =>
        Math.Max(1, (int)Math.Ceiling(FilteredEntries.Count / (double)PageSize));

    private List<JournalEntry> PagedEntries =>
        FilteredEntries.Skip((_page - 1) * PageSize).Take(PageSize).ToList();

    private void Next() => _page++;
    private void Prev() => _page--;

    private async Task Edit(JournalEntry entry)
    {
        if (entry.IsLocked && !unlockedEntries.Contains(entry.Id))
        {
            if (!await PinService.HasPinAsync())
            {
                await JS.InvokeVoidAsync("alert", "Security Alert: No PIN has been set in Settings. Please configure a PIN to secure your locked entries.");
                Nav.NavigateTo($"/edit/{entry.Id}");
                return;
            }

            pendingEntry = entry;
            navigateAfterUnlock = true;
            showPinPrompt = true;
            enteredPin = "";
            pinError = "";
        }
        else
        {
            Nav.NavigateTo($"/edit/{entry.Id}");
        }
    }

    private async Task Delete(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this entry?")) return;
        await Storage.DeleteEntryAsync(id);
        allEntries = await Storage.GetEntriesAsync() ?? new();
        UpdateAllTags();
        ApplyFilter();
    }

    private async Task LockEntry(JournalEntry entry)
    {
        entry.IsLocked = true;
        await Storage.UpdateEntryAsync(entry);
        unlockedEntries.Remove(entry.Id); // Ensure it's treated as locked in this session too
    }

    private async Task RequestUnlock(JournalEntry entry)
    {
        if (!await PinService.HasPinAsync())
        {
            await JS.InvokeVoidAsync("alert", "No PIN set! Please set a security PIN in Settings first.");
            return;
        }

        pendingEntry = entry;
        navigateAfterUnlock = false;
        showPinPrompt = true;
        enteredPin = "";
        pinError = "";
    }

    private async Task UnlockAndProceed()
    {
        if (!await PinService.ValidatePinAsync(enteredPin))
        {
            pinError = "Incorrect PIN";
            return;
        }

        pendingEntry!.IsLocked = false;
        await Storage.UpdateEntryAsync(pendingEntry);
        unlockedEntries.Add(pendingEntry.Id);
        showPinPrompt = false;

        if (navigateAfterUnlock)
            Nav.NavigateTo($"/edit/{pendingEntry.Id}");
    }

    private void CancelUnlock()
    {
        showPinPrompt = false;
        enteredPin = "";
        pinError = "";
        pendingEntry = null;
        navigateAfterUnlock = false;
    }

    private async Task ExportSingleEntry(JournalEntry entry)
{
    if (entry.IsLocked && !unlockedEntries.Contains(entry.Id))
    {
        pendingEntry = entry;
        exportAfterUnlock = true; // mark that export should happen after unlocking
        showPinPrompt = true;
        enteredPin = "";
        pinError = "";
        return; // wait for PIN
    }

    await DoExportSingleEntry(entry);
}

private async Task DoExportSingleEntry(JournalEntry entry)
{
    var pdf = await PdfService.ExportJournalEntriesAsync(entry.CreatedAt, entry.CreatedAt);

    await JS.InvokeVoidAsync(
        "downloadFile",
        $"Journal_{entry.CreatedAt:yyyyMMdd}.pdf",
        "application/pdf",
        pdf);
}

    private async Task ExportFiltered()
{
    if (!FilteredEntries.Any())
        return;

    // determine date range
    var from = startDate ?? FilteredEntries.Min(e => e.CreatedAt);
    var to   = endDate   ?? FilteredEntries.Max(e => e.CreatedAt);

    var pdfBytes = await PdfService.ExportJournalEntriesAsync(from, to);

    await JS.InvokeVoidAsync(
        "downloadFile",
        $"Journal_Filtered_{from:yyyyMMdd}_{to:yyyyMMdd}.pdf",
        "application/pdf",
        pdfBytes);
}


    private readonly Dictionary<string, List<string>> MoodCategories = new()
    {
        ["Positive"] = new() { "Happy", "Excited", "Relaxed", "Grateful", "Confident" },
        ["Neutral"]  = new() { "Calm", "Thoughtful", "Curious", "Nostalgic", "Bored" },
        ["Negative"] = new() { "Sad", "Angry", "Stressed", "Lonely", "Anxious" }
    };

    private readonly Dictionary<string, string> MoodEmojis = new()
    {
        { "Happy", "😊" }, { "Excited", "🤩" }, { "Relaxed", "😌" },
        { "Grateful", "🙏" }, { "Confident", "💪" },

        { "Calm", "😐" }, { "Thoughtful", "🤔" }, { "Curious", "🧐" },
        { "Nostalgic", "🕰️" }, { "Bored", "🥱" },

        { "Sad", "😢" }, { "Angry", "😠" }, { "Stressed", "😣" },
        { "Lonely", "🥺" }, { "Anxious", "😰" }
    };

    private string GetMoodEmoji(string? mood)
        => mood != null && MoodEmojis.TryGetValue(mood, out var e) ? e : "🙂";
}

