@page "/entry/{Id:guid}"
@using JournalApp.Models
@inject JournalApp.Services.IJournalStorageService Storage
@inject NavigationManager Nav

<h3>Entry Details</h3>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (entry == null)
{
    <div class="alert alert-warning">
        Entry not found or may have been deleted.
    </div>
    <button class="btn btn-secondary" @onclick="Back">Back</button>
}
else
{
    <div class="card p-3">
        <h4>@(entry.Title ?? "Untitled")</h4>

        <div class="text-muted">
            @entry.CreatedAt.ToString("D") • @(entry.PrimaryMood ?? "No mood")
        </div>

        <hr />

        <div>
            @((MarkupString)MarkdownToHtml(entry.Content ?? string.Empty))
        </div>

        <hr />

        <div>
            <strong>Secondary Moods:</strong>
            @(entry.SecondaryMoods != null && entry.SecondaryMoods.Any()
                ? string.Join(", ", entry.SecondaryMoods)
                : "None")
        </div>

        <div>
            <strong>Tags:</strong>
            @(entry.Tags != null && entry.Tags.Any()
                ? string.Join(", ", entry.Tags)
                : "None")
        </div>

        <div class="mt-3">
            <button class="btn btn-primary" @onclick="Edit">Edit</button>
            <button class="btn btn-secondary ms-2" @onclick="Back">Back</button>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private JournalEntry? entry;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        entry = await Storage.GetEntryAsync(Id);
        isLoading = false;
    }

    private string MarkdownToHtml(string md)
    {
        if (string.IsNullOrWhiteSpace(md)) return string.Empty;

        var html = System.Net.WebUtility.HtmlEncode(md);
        html = html.Replace("\n", "<br />");
        html = System.Text.RegularExpressions.Regex.Replace(html, "\\*\\*(.+?)\\*\\*", "<strong>$1</strong>");
        html = System.Text.RegularExpressions.Regex.Replace(html, "\\*(.+?)\\*", "<em>$1</em>");
        html = System.Text.RegularExpressions.Regex.Replace(
            html,
            @"\[(.+?)\]\((.+?)\)",
            "<a href=\"$2\" target=\"_blank\">$1</a>"
        );

        return html;
    }

    private void Edit()
    {
        if (entry != null)
            Nav.NavigateTo($"/edit/{entry.Id}");
    }

    private void Back()
    {
        Nav.NavigateTo("/view-entries");
    }
}
