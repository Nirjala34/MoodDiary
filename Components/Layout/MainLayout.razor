@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="page @(isCollapsed ? "sidebar-collapsed" : "") @(isDark ? "dark-mode" : "")">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <h2 class="brand-title">MoodDiary</h2>
            <button class="btn-toggle" @onclick="ToggleSidebar">
                <i class="bi @(isCollapsed ? "bi-text-indent-left" : "bi-text-indent-right")"></i>
            </button>
        </div>

        <NavMenu />

        <div class="sidebar-footer">
            <!-- Theme Toggle -->
            <button class="theme-toggle-btn" @onclick="ToggleTheme" title="Toggle Theme">
                <i class="bi @(isDark ? "bi-sun-fill" : "bi-moon-stars-fill")"></i>
                <span class="nav-text">@(isDark ? "Light Mode" : "Dark Mode")</span>
            </button>
        </div>
    </aside>

    <main>
        <div class="app-container">
            @Body
        </div>
    </main>
</div>

@code {
    private bool isCollapsed = false;
    private bool isDark = false;

    protected override async Task OnInitializedAsync()
    {
        var saved = await JS.InvokeAsync<string>("localStorage.getItem", "theme");
        isDark = saved == "dark";
    }

    private void ToggleSidebar()
    {
        isCollapsed = !isCollapsed;
    }

    private async Task ToggleTheme()
    {
        isDark = !isDark;
        await JS.InvokeVoidAsync("localStorage.setItem", "theme", isDark ? "dark" : "light");
    }
}
