
<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
<input type="checkbox" title="Navigation menu" class="navbar-toggler" />


<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column nav-section">

        <!-- HOME -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door"></span>  Home
            </NavLink>
        </div>

        <!-- DASHBOARD -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="dashboard">
                <span class="bi bi-speedometer2"></span> Dashboard
            </NavLink>
        </div>

        <!-- JOURNAL DROPDOWN -->
        <div class="nav-item px-3 journal-dropdown">

            <!-- Journal Header -->
            <div class="nav-link journal-toggle" @onclick="ToggleJournal">
                <span class="bi bi-journal-bookmark"></span> Journal 
                <span class="bi @(isJournalOpen ? "bi-caret-up-fill" : "bi-caret-down-fill")"></span>
            </div>

            <!-- Dropdown Items -->
            @if (isJournalOpen)
            {
                <div class="journal-submenu ms-4">

                    <NavLink class="nav-link" href="add-entry">
                        <span class="bi bi-journal-plus"></span>  Add Entry
                    </NavLink>

                    <NavLink class="nav-link" href="view-entries">
                        <span class="bi bi-journal-text"></span>  View Entries
                    </NavLink>

                    <NavLink class="nav-link" href="calendar">
                        <span class="bi bi-calendar-event"></span> Calendar
                    </NavLink>

                </div>
            }
        </div>

        <!-- ANALYTICS -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="analytics">
                <span class="bi bi-bar-chart-line"></span>  Analytics
            </NavLink>
        </div>

        <!-- SETTINGS -->
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="settings">
                <span class="bi bi-gear"></span>  Settings
            </NavLink>
        </div>

    </nav>
</div>
@code {
    private bool isJournalOpen = false;

    private void ToggleJournal()
    {
        isJournalOpen = !isJournalOpen;
    }
}
