
<div class="nav-scrollable">
    <nav class="nav-section d-flex flex-column gap-1">

        <div class="nav-item">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                <i class="bi bi-house-door"></i> <span class="nav-text">Home</span>
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="/dashboard">
                <i class="bi bi-grid-1x2"></i> <span class="nav-text">Dashboard</span>
            </NavLink>
        </div>

        <div class="nav-item">
            <div class="nav-link journal-toggle" @onclick="ToggleJournal" style="cursor: pointer;">
                <i class="bi bi-journal-text"></i> <span class="nav-text">Journal</span>
                <i class="bi @(isJournalOpen ? "bi-chevron-up" : "bi-chevron-down") ms-auto small nav-text"></i>
            </div>

            @if (isJournalOpen)
            {
                <div class="journal-submenu d-flex flex-column gap-1 mt-1 ms-3 border-start border-opacity-10 ps-2">
                    <NavLink class="nav-link small" href="/add-entry">
                        <i class="bi bi-plus-circle"></i> <span class="nav-text">New Entry</span>
                    </NavLink>
                    <NavLink class="nav-link small" href="/view-entries">
                        <i class="bi bi-list-task"></i> <span class="nav-text">View Entries</span>
                    </NavLink>
                    <NavLink class="nav-link small" href="/calendar">
                        <i class="bi bi-calendar3"></i> <span class="nav-text">Calendar</span>
                    </NavLink>
                </div>
            }
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="/analytics">
                <i class="bi bi-graph-up"></i> <span class="nav-text">Analytics</span>
            </NavLink>
        </div>

        <div class="nav-item">
            <NavLink class="nav-link" href="/settings">
                <i class="bi bi-gear"></i> <span class="nav-text">Settings</span>
            </NavLink>
        </div>

    </nav>
</div>

@code {
    private bool isJournalOpen = true;

    private void ToggleJournal()
    {
        isJournalOpen = !isJournalOpen;
    }
}
